{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared-types": [
        "packages/shared-types/src/index.ts"
      ],
      "@shared-types/*": [
        "packages/shared-types/src/*"
      ]
    },
    "outDir": "dist"
  }
}