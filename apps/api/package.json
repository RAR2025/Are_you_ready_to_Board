{
  "name": "@onboard/api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/start.ts",
    "dev:worker": "tsx watch src/queue/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/queue/worker.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@onboard/shared-types": "1.0.0",
    "bullmq": "^5.19.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.5.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "firebase-admin": "^12.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5"
  }
}
