DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onboard_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=onboard_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Firebase Admin SDK credentials. Use exactly one setup:
# 1. Preferred: point to the service account JSON file for the same Firebase project.
# 2. Alternative: provide FIREBASE_PROJECT_ID, FIREBASE_PRIVATE_KEY, and FIREBASE_CLIENT_EMAIL.
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# Optional but recommended for consistency checks when using service account path:
FIREBASE_PROJECT_ID=are-you-ready-to-board
# Optional when using service account path:
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@are-you-ready-to-board.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
